{
  "name": "autoledger",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --parallel --filter mobile --filter web dev",
    "build": "pnpm -r --if-present build",
    "e2e:mobile": "maestro test apps/mobile/e2e/maestro",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm run test:unit && pnpm run test:web && pnpm run test:mobile",
    "test:mobile": "pnpm --filter mobile test",
    "test:unit": "pnpm --filter @autoledger/shared --filter @autoledger/validation test",
    "test:web": "pnpm --filter web test",
    "test:watch": "pnpm --parallel --filter @autoledger/shared --filter @autoledger/validation test:watch",
    "typecheck": "pnpm -r --if-present typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "eslint": "9.39.4",
    "globals": "17.5.0",
    "prettier": "3.8.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.59.1",
    "vitest": "^4.1.5"
  }
}
